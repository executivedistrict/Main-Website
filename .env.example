# Executive District - environment variables
# Copy to .env.local (gitignored) and fill in real values.

# Tavus credentials for the Jacob AI concierge (POST /api/jacob/conversation).
# All three are SERVER-ONLY: never prefix with NEXT_PUBLIC_ and never expose
# them in a response body or client bundle.
TAVUS_API_KEY=
TAVUS_REPLICA_ID=
TAVUS_PERSONA_ID=

# Resend API key for the lead-qualification emails (POST /api/qualify and
# /api/lead-contact). SERVER-ONLY: never prefix with NEXT_PUBLIC_ and never
# expose it in a response body or client bundle. The FROM address is
# hard-coded in src/lib/email/resend.ts (the authorized sender for this
# key); the NOTIFY address lives in src/lib/qualification/config.ts
# (notifications.internalContact), edited alongside the qualification rules.
RESEND_API_KEY=

# Note: the delivered plugin (docs/jacob-concierge-plugin-v2/) also used
# ALLOWED_ORIGINS and NODE_ENV for its CORS layer. Those are intentionally
# dropped here: the Next.js route is same-origin, so no CORS layer is ported.
